# ── BUILD OUTPUTS ──────────────────────────────────────────
# Compiled APK/AAB files — these are generated, not source
*.apk
*.aab
*.ap_
*.aar

# Dalvik/ART bytecode — machine-generated from .class files
*.dex

# Java class files — compiled output, not source
*.class

# Gradle build output folders
build/
.gradle/

# CMake / NDK native build outputs (your C++ JNI code)
.externalNativeBuild/
.cxx/

# Generated source folders (R.java, BuildConfig, etc.)
gen/
out/

# ── LOCAL ENVIRONMENT ──────────────────────────────────────
# SDK path is machine-specific — differs per developer
local.properties

# ── IDE FILES ──────────────────────────────────────────────
# IntelliJ/Android Studio module files — auto-regenerated
*.iml

# .idea folder contains IDE workspace state (mostly local)
.idea/

# Specific IDE metadata files
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# ── KOTLIN SPECIFIC ────────────────────────────────────────
# Kotlin compiler cache — regenerated on each build
.kotlin/

# ── LOGS & PROFILING ───────────────────────────────────────
# Log files — runtime output, not part of source
*.log

# Android memory heap dumps — for profiling only, not source
*.hprof

# ── ANDROID STUDIO SPECIFIC ────────────────────────────────
# Profiler captures — local debugging sessions
captures/

# Navigation editor temp files
.navigation/

# Build metadata file — regenerated by Gradle
output-metadata.json

# ── SECURITY — NEVER COMMIT THESE ─────────────────────────
# Keystore files contain your app signing keys — leaking = disaster
*.jks
*.keystore

# Firebase config — contains project IDs and API keys
google-services.json

# ── OS JUNK FILES ──────────────────────────────────────────
# macOS folder metadata
.DS_Store

# Windows thumbnail cache
Thumbs.db