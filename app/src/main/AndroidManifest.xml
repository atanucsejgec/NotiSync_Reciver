<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- (1) Internet permission — required to fetch notifications from Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- (2) Network state — check connectivity before fetching -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- (3) Post notifications — required on Android 13+ to show received notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- (4) Wake lock — used by WorkManager for background sync -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application

    android:name=".NotiSyncReceiverApp"

    android:allowBackup="false"
    android:dataExtractionRules="@xml/data_extraction_rules"
    android:fullBackupContent="@xml/backup_rules"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_round"
    android:supportsRtl="true"
    android:theme="@style/Theme.NotiSyncReceiver"

    tools:targetApi="34">

    <activity
        android:name=".MainActivity"
        android:exported="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.NotiSyncReceiver">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />

            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <!-- (8) WorkManager Initializer Override for Hilt -->
    <provider
        android:name="androidx.startup.InitializationProvider"
        android:authorities="${applicationId}.androidx-startup"
        android:exported="false"
        tools:node="merge">
        <meta-data
            android:name="androidx.work.WorkManagerInitializer"
            android:value="androidx.startup"
            tools:node="remove" />
    </provider>

</application>

    </manifest>